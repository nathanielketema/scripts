#!/usr/bin/env bun

import { $ } from "bun";

await main();

async function main(): Promise<void> {
    if (Bun.argv.length != 3) {
        help();
        process.exit(1);
    }
    const command = Bun.argv[2];

    switch (command) {
        case "brew":
            await brew();
            break;
        default:
            help();
    }
}

async function brew(): Promise<void> {
    await $`brew update`;
    await $`brew upgrade`;
    await $`brew bundle install --global`;
    await $`brew bundle cleanup --global --force --zap`;
    await $`brew cleanup --prune=all`;
}

function help(): void {
    console.log("Usage: config <command>\n");
    console.log("Available commands:");
    console.log("    brew - Keeps all packages and casks upto date with the Brewfile");
}

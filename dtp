#!/usr/bin/env bun

import { $ } from "bun";
import { existsSync } from "node:fs";
import path from "node:path";

type App_name = "Pages";

const supported_extensions = new Set([".docx", ".doc", ".pages"]);

function show_usage(): void {
    console.log("Usage: dtp [directory | file1.docx file2.pages ...]");
    console.log("");
    console.log("Examples:");
    console.log("  dtp .             # Convert all docs in current folder");
    console.log("  dtp report.docx   # Convert specific file");
    console.log("  dtp *.docx        # Convert all docx using wildcard");
}

function get_output_path(input_path: string): string {
    const parsed_path = path.parse(input_path);
    return path.join(parsed_path.dir, `${parsed_path.name}.pdf`);
}

async function collect_directory_files(directory_path: string): Promise<string[]> {
    const entries = await Array.fromAsync(new Bun.Glob("*").scan({ cwd: directory_path, onlyFiles: true }));
    return entries
        .filter((entry) => supported_extensions.has(path.extname(entry).toLowerCase()))
        .map((entry) => path.join(directory_path, entry));
}

async function collect_files(argv: string[]): Promise<string[]> {
    if (argv.length === 0) {
        return [];
    }

    const first_arg = argv[0];
    if (first_arg === "." || existsSync(first_arg) && (await Bun.file(first_arg).stat()).isDirectory()) {
        const directory_path = path.resolve(first_arg === "." ? "." : first_arg);
        return collect_directory_files(directory_path);
    }

    const files_to_process: string[] = [];
    for (const arg of argv) {
        if (supported_extensions.has(path.extname(arg).toLowerCase())) {
            files_to_process.push(path.resolve(arg));
        } else {
            console.log(`Skipping ${arg} (not a supported document format)`);
        }
    }

    return files_to_process;
}

async function close_app(app_name: App_name): Promise<void> {
    await $`osascript -e ${`
        if application "${app_name}" is running then
            tell application "${app_name}" to quit
        end if
    `}`.quiet().nothrow();
}

async function convert_file(input_path: string): Promise<void> {
    const absolute_input_path = path.resolve(input_path);
    const output_path = get_output_path(absolute_input_path);

    console.log(`Converting: ${absolute_input_path} -> ${path.basename(output_path)}`);
    await $`osascript -e ${`
        tell application "Pages"
            activate
            set the_document to open POSIX file "${absolute_input_path}"
            delay 0.5
            export the_document to file (POSIX file "${output_path}") as PDF
            close the_document saving no
        end tell
    `}`;
}

async function main(): Promise<void> {
    const args = process.argv.slice(2);

    if (args.length === 0) {
        show_usage();
        process.exit(1);
    }

    const files_to_process = await collect_files(args);
    if (files_to_process.length === 0) {
        console.error("Error: No supported document files found.");
        process.exit(1);
    }

    try {
        for (const file_path of files_to_process) {
            await convert_file(file_path);
        }

        console.log(`Done! Processed ${files_to_process.length} file(s).`);
    } finally {
        await close_app("Pages");
    }
}

await main();

#!/usr/bin/env bun

import { $ } from "bun";

const source_path = `/Users/nathaniel/Library/Mobile Documents/com~apple~CloudDocs/`;
const backup_path = `${process.env.HOME}/.backup/`;

const folders = ["personal", "school", "work", "misc"];
const deadlock_pattern = /^rsync\(\d+\): error: (.*): mmap: Resource deadlock avoided\s*$/gm;

type Shell_error = Error & {
    stderr?: string;
};

function get_deadlock_paths(stderr: string): string[] {
    const file_paths = new Set<string>();

    for (const match of stderr.matchAll(deadlock_pattern)) {
        file_paths.add(match[1]);
    }

    return Array.from(file_paths);
}

async function hydrate_files(file_paths: string[]): Promise<void> {
    for (const file_path of file_paths) {
        console.log(`Hydrating iCloud file: ${file_path}`);
        await $`/usr/bin/brctl download ${file_path}`;
    }
}

async function sync_folder(folder: string): Promise<void> {
    const src = `${source_path}${folder}/`;
    const dest = `${backup_path}${folder}/`;

    console.log(`Syncing ${folder}...`);

    try {
        await $`rsync -av --delete \
      --exclude='.git' \
      --exclude='node_modules' \
      --exclude='.zig-cache' \
      --exclude='zig-pkg' \
      --exclude='__pycache__' \
      --exclude='.pytest_cache' \
      --exclude='*.pyc' \
      --exclude='.DS_Store' \
      ${src} ${dest}`;
    } catch (err) {
        const error = err as Shell_error;
        const stderr = error.stderr?.toString() ?? "";
        const deadlock_paths = get_deadlock_paths(stderr);

        if (deadlock_paths.length === 0) {
            throw error;
        }

        await hydrate_files(deadlock_paths);
        await $`rsync -av --delete \
      --exclude='.git' \
      --exclude='node_modules' \
      --exclude='.zig-cache' \
      --exclude='zig-pkg' \
      --exclude='__pycache__' \
      --exclude='.pytest_cache' \
      --exclude='*.pyc' \
      --exclude='.DS_Store' \
      ${src} ${dest}`;
    }
}

async function run_backup(): Promise<void> {
    console.log("Starting Sync...");

    const exists = await $`ls ${backup_path}`.quiet().nothrow();
    if (exists.exitCode !== 0) {
        throw new Error("Backup directory not found!");
    }

    for (const folder of folders) {
        await sync_folder(folder);
    }

    console.log("Committing to git...");
    process.chdir(backup_path);

    await $`git config advice.addEmbeddedRepo false`.nothrow().quiet();
    await $`git config core.safecrlf false`.nothrow().quiet();
    await $`git add .`.quiet();

    // Only commit if there are actually changes to avoid "empty" commits
    const status = await $`git status --porcelain`.text();
    if (status.length > 0) {
        const date = new Date().toLocaleString();
        await $`git commit -m "Backup: ${date}"`;
        console.log("Success..backup complete and committed.");
    } else {
        console.log("Success..no changes detected. Git is already up to date.");
    }
}

export async function scheduled(): Promise<void> {
    await run_backup();
}

export default { scheduled };

if (import.meta.main) {
    try {
        await run_backup();
    } catch (err) {
        const error = err as Error;
        console.error(`Fail..Backup failed: ${error.message}`);
        process.exit(1);
    }
}
